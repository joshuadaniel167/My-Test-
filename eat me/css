/* General Reset */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: Arial, sans-serif;
  line-height: 1.6;
  background: rgb(130, 94, 163)
  color: #333;
}

/* Header */
header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ff5722;
  padding: 15px 30px;
  color: #fff;
}

header .logo {
  font-size: 1.5rem;
  font-weight: bold;
}

nav ul {
  list-style: none;
  display: flex;
}

nav ul li {
  margin-left: 20px;
}

nav ul li a {
  color: #fff;
  text-decoration: none;
  font-weight: bold;
}

/* Hero */
.hero {
  text-align: center;
  padding: 60px 20px;
  background: #ffe0b2;
}

.hero h1 {
  font-size: 2.5rem;
  margin-bottom: 15px;
}

.hero .btn {
  display: inline-block;
  padding: 10px 20px;
  background: #ff5722;
  color: #fff;
  text-decoration: none;
  border-radius: 5px;
  margin-top: 20px;
}

/* Menu */
.menu {
  padding: 40px 20px;
  text-align: center;
}

.menu-items {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 20px;
}

.menu-items .item {
  background: #fff;
  padding: 15px;
  border-radius: 10px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  width: 200px;
}

.menu-items img {
  width: 100%;
  border-radius: 10px;
}

.menu-items button {
  margin-top: 10px;
  padding: 8px;
  background: #ff5722;
  color: #fff;
  border: none;
  border-radius: 5px;
  cursor: pointer;
}

/* Order Form */
.order {
  padding: 40px 20px;
  text-align: center;
}

.order form {
  max-width: 400px;
  margin: auto;
  display: flex;
  flex-direction: column;
}

.order input, .order textarea {
  margin-bottom: 15px;
  padding: 10px;
  border: 1px solid #ccc;
  border-radius: 5px;
}

.order button {
  padding: 10px;
  background: #ff5722;
  color: #fff;
  border: none;
  border-radius: 5px;
  cursor: pointer;
}

/* About */
.about {
  padding: 40px 20px;
  text-align: center;
}

.about img {
  max-width: 300px;
  margin-top: 20px;
  border-radius: 10px;
}

/* Footer */
footer {
  background: #ff5722;
  color: #fff;
  text-align: center;
  padding: 15px;
}
